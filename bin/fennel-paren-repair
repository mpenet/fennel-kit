#!/usr/bin/env fennel
;; fennel-paren-repair — Fix delimiter errors in Fennel files.
;;
;; Usage:
;;   fennel-paren-repair [--fnlfmt] [FILE ...]   ;; fix files in place
;;   echo "(foo bar" | fennel-paren-repair        ;; fix stdin, output to stdout
;;
;; Optional env:
;;   PARINFER_RUST_PATH  — path to parinfer-rust binary (default: parinfer-rust from PATH)

(local fennel (require :fennel))

(fn dirname [path]
  (or (path:match "^(.*)/[^/]*$") "."))

(fn file-exists? [path]
  (let [f (io.open path :r)]
    (when f (f:close) true)))

(local lib-dir
  (accumulate [found nil _ dir (ipairs [(.. (os.getenv "HOME") "/.local/lib/fennel-kit")
                                        "/usr/local/lib/fennel-kit"
                                        (.. (dirname (. arg 0)) "/../lib")])
               &until found]
    (when (file-exists? (.. dir "/parinfer.fnl")) dir)))

(local parinfer-bin (or (os.getenv "PARINFER_RUST_PATH") "parinfer-rust"))
(var fnlfmt? false)
(local files
  (icollect [_ a (ipairs arg)]
    (if (= a "--fnlfmt")
      (do (set fnlfmt? true) nil)
      a)))

(fn which? [cmd]
  (let [f (io.popen (.. "command -v '" cmd "' 2>/dev/null"))]
    (when f
      (let [r (f:read :*a)]
        (f:close)
        (and r (> (# r) 0))))))

(local has-parinfer? (which? parinfer-bin))

(when (not (or has-parinfer? lib-dir))
  (io.stderr:write "Error: parinfer-rust not found and Fennel fallback unavailable.\n")
  (io.stderr:write "Install parinfer-rust or run: make install-eval\n")
  (os.exit 1))

(var repair-fn nil)

(fn do-repair [content]
  (if has-parinfer?
    (let [fin (os.tmpname)
          fout (os.tmpname)]
      (with-open [f (io.open fin :w)]
        (f:write content))
      (os.execute (string.format "'%s' --mode indent --language fennel 2>/dev/null < '%s' > '%s'"
                                 parinfer-bin fin fout))
      (let [f (io.open fout :r)
            result (when f (let [r (f:read :*a)] (f:close) r))]
        (os.remove fin)
        (os.remove fout)
        (if (and result (> (# result) 0)) result content)))
    (do
      (when (not repair-fn)
        (set repair-fn (. (fennel.dofile (.. lib-dir "/parinfer.fnl")) :repair)))
      (repair-fn content))))

(fn repair-file [path]
  (let [original (with-open [f (assert (io.open path :r))]
                   (f:read :*a))
        repaired (do-repair original)]
    (if (= original repaired)
      (print (.. "  " path ": unchanged"))
      (do
        (with-open [f (assert (io.open path :w))]
          (f:write repaired))
        (print (.. "  " path ": fixed"))))
    (when (and fnlfmt? (which? "fnlfmt"))
      (os.execute (string.format "fnlfmt --fix '%s' 2>/dev/null" path)))))

(if (= (# files) 0)
  (io.write (do-repair (io.read :*a)))
  (do
    (print "")
    (print "fennel-paren-repair Results")
    (print "===========================")
    (print "")
    (var failed? false)
    (each [_ path (ipairs files)]
      (if (not (file-exists? path))
        (do (print (.. "  " path ": not found")) (set failed? true))
        (if (not (path:match "%.fnl$"))
          (print (.. "  " path ": skipped (not a .fnl file)"))
          (repair-file path))))
    (print "")
    (os.exit (if failed? 1 0))))
