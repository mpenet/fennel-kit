#!/usr/bin/env fennel
;; fennel-paren-repair-hook — Claude Code hook for Fennel delimiter repair.
;; Intercepts Write/Edit on .fnl files and repairs parens.
;;
;; Add to ~/.claude/settings.json:
;;   "hooks": {
;;     "PreToolUse":  [{"matcher": "Write|Edit", "hooks": [{"type": "command", "command": "fennel-paren-repair-hook --fnlfmt"}]}],
;;     "PostToolUse": [{"matcher": "Write|Edit", "hooks": [{"type": "command", "command": "fennel-paren-repair-hook --fnlfmt"}]}]
;;   }
;;
;; Drop --fnlfmt if you don't want fnlfmt to run after repair.
;;
;; Optional env:
;;   PARINFER_RUST_PATH  — path to parinfer-rust binary (default: parinfer-rust from PATH)

(local fennel (require :fennel))

(fn dirname [path]
  (or (path:match "^(.*)/[^/]*$") "."))

(fn file-exists? [path]
  (let [f (io.open path :r)]
    (when f (f:close) true)))

(local lib-dir
  (accumulate [found nil _ dir (ipairs [(.. (os.getenv "HOME") "/.local/lib/fennel-kit")
                                        "/usr/local/lib/fennel-kit"
                                        (.. (dirname (. arg 0)) "/../lib")])
               &until found]
    (when (file-exists? (.. dir "/parinfer.fnl")) dir)))

(when (not lib-dir) (os.exit 0))

(local parinfer-bin (or (os.getenv "PARINFER_RUST_PATH") "parinfer-rust"))
(local fnlfmt? (accumulate [found false _ a (ipairs arg) &until found]
                 (= a "--fnlfmt")))


(fn which? [cmd]
  (let [f (io.popen (.. "command -v '" cmd "' 2>/dev/null"))]
    (when f
      (let [r (f:read :*a)]
        (f:close)
        (and r (> (# r) 0))))))

(local has-parinfer? (which? parinfer-bin))

(local json
  (let [(chunk err) (loadfile (.. lib-dir "/json.lua"))]
    (when (not chunk)
      (io.stderr:write (.. "Error loading json.lua: " (tostring err) "\n"))
      (os.exit 1))
    (chunk)))

(var repair-fn nil)

(fn do-repair [content]
  (if has-parinfer?
    (let [fin (os.tmpname)
          fout (os.tmpname)]
      (with-open [f (io.open fin :w)]
        (f:write content))
      (os.execute (string.format "'%s' --mode indent --language fennel 2>/dev/null < '%s' > '%s'"
                                 parinfer-bin fin fout))
      (let [f (io.open fout :r)
            result (when f (let [r (f:read :*a)] (f:close) r))]
        (os.remove fin)
        (os.remove fout)
        (if (and result (> (# result) 0)) result content)))
    (do
      (when (not repair-fn)
        (set repair-fn (. (fennel.dofile (.. lib-dir "/parinfer.fnl")) :repair)))
      (repair-fn content))))

(fn fnl? [path]
  (and (= (type path) :string) (path:match "%.fnl$")))

(local input (io.read :*a))
(local data (json.decode input))
(local event (or (. data :hook_event_name) ""))
(local tool (or (. data :tool_name) ""))

(match (.. event "/" tool)
  "PreToolUse/Write"
  (let [ti (. data :tool_input)
        path (and ti (. ti :file_path))]
    (when (fnl? path)
      (let [content (or (. ti :content) "")
            repaired (do-repair content)]
        (when (not= content repaired)
          (let [updated (collect [k v (pairs ti)] (values k v))]
            (tset updated :content repaired)
            (io.write (json.encode
                        {:hookSpecificOutput
                         {:hookEventName "PreToolUse"
                          :permissionDecision "allow"
                          :updatedInput updated}}))
            (io.write "\n"))))))

  "PostToolUse/Edit"
  (let [ti (. data :tool_input)
        path (and ti (. ti :file_path))
        resp (. data :tool_response)]
    (when (and (fnl? path) (file-exists? path) resp)
      (let [original (with-open [f (assert (io.open path :r))]
                       (f:read :*a))
            repaired (do-repair original)]
        (when (not= original repaired)
          (with-open [f (assert (io.open path :w))]
            (f:write repaired)))
        (when (and fnlfmt? (which? "fnlfmt"))
          (os.execute (string.format "fnlfmt --fix '%s' 2>/dev/null" path)))
        ))))
